<%- include('../partials/head') %>
<div class="dashboard-layout">
  <%- include('../partials/admin-sidebar', { active: 'withdrawals' }) %>
  <div class="dashboard-main">
    <div class="dashboard-topbar"><h4 class="mb-0">Manage Withdrawals</h4></div>
    <div class="dashboard-content">
      <%- include('../partials/flash') %>
      <div class="dash-card">
        <div class="table-responsive">
          <table class="table dash-table">
            <thead>
              <tr><th>User</th><th>Channel</th><th>Wallet Address</th><th>Amount</th><th>Status</th><th>Date</th><th>Action</th></tr>
            </thead>
            <tbody>
              <% withdrawals.forEach(w => { %>
              <tr>
                <td>
                  <strong><%= w.user ? w.user.username : 'N/A' %></strong>
                  <br><small class="text-muted"><%= w.user ? w.user.email : '' %></small>
                </td>
                <td><span class="badge bg-secondary"><%= w.channel %></span></td>
                <td><code class="small text-break" style="font-size:0.72rem;max-width:160px;display:block;">
                  <%= w.walletAddress %>
                </code></td>
                <td><strong>$<%= w.amount.toFixed(2) %></strong></td>
                <td><span class="badge bg-<%= w.status === 'approved' ? 'success' : w.status === 'rejected' ? 'danger' : 'warning text-dark' %>">
                  <%= w.status %>
                </span></td>
                <td class="text-muted small"><%= new Date(w.createdAt).toLocaleDateString() %></td>
                <td>
                  <% if (w.status === 'pending') { %>
                  <form action="/admin/withdrawals/<%= w._id %>/approve" method="POST" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-xs btn-success me-1">Approve</button>
                  </form>
                  <form action="/admin/withdrawals/<%= w._id %>/reject" method="POST" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-xs btn-danger">Reject</button>
                  </form>
                  <% } else { %><span class="text-muted">—</span><% } %>
                </td>
              </tr>
              <% }) %>
              <% if (!withdrawals.length) { %>
              <tr><td colspan="7" class="text-center py-4 text-muted">No withdrawals.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
