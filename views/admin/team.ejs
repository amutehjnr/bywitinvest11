<%- include('../partials/head') %>
<div class="dashboard-layout">
  <%- include('../partials/admin-sidebar', { active: 'team' }) %>
  <div class="dashboard-main">
    <div class="dashboard-topbar"><h4 class="mb-0">Manage Team</h4></div>
    <div class="dashboard-content">
      <%- include('../partials/flash') %>
      <div class="row">
        <div class="col-lg-4 mb-4">
          <div class="dash-card">
            <div class="dash-card-header"><h6>Add Team Member</h6></div>
            <form action="/admin/team" method="POST" enctype="multipart/form-data">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-3"><label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control" maxlength="80" required></div>
              <div class="mb-3"><label class="form-label">Position/Role</label>
                <input type="text" name="position" class="form-control" maxlength="100" required></div>
              <div class="mb-3"><label class="form-label">Photo</label>
                <input type="file" name="photo" class="form-control" accept="image/*"></div>
              <button type="submit" class="btn btn-theme w-100">Add Member</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="row">
            <% team.forEach(t => { %>
            <div class="col-md-4 mb-3">
              <div class="dash-card text-center">
                <% if (t.photo) { %>
                  <img src="<%= t.photo %>" alt="<%= t.name %>" class="rounded-circle mb-2" style="width:70px;height:70px;object-fit:cover;">
                <% } else { %>
                  <div class="avatar-placeholder mx-auto mb-2" style="width:70px;height:70px;font-size:1.5rem;"><%= t.name.charAt(0) %></div>
                <% } %>
                <h6 class="mb-0"><%= t.name %></h6>
                <small class="text-muted"><%= t.position %></small>
                <div class="mt-2">
                  <form action="/admin/team/<%= t._id %>/delete" method="POST" onsubmit="return confirm('Delete?')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-xs btn-outline-danger"><i class="fas fa-trash"></i></button>
                  </form>
                </div>
              </div>
            </div>
            <% }) %>
            <% if (!team.length) { %><div class="col-12 text-center py-4 text-muted">No team members yet.</div><% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
