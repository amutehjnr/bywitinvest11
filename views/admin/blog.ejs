<%- include('../partials/head') %>
<div class="dashboard-layout">
  <%- include('../partials/admin-sidebar', { active: 'blog' }) %>
  <div class="dashboard-main">
    <div class="dashboard-topbar"><h4 class="mb-0">Manage Blog</h4></div>
    <div class="dashboard-content">
      <%- include('../partials/flash') %>
      <div class="row">
        <div class="col-lg-5 mb-4">
          <div class="dash-card">
            <div class="dash-card-header"><h6>Add New Post</h6></div>
            <form action="/admin/blog" method="POST" enctype="multipart/form-data">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-3"><label class="form-label">Headline</label>
                <input type="text" name="headline" class="form-control" maxlength="200" required></div>
              <div class="mb-3"><label class="form-label">Intro</label>
                <textarea name="intro" class="form-control" rows="2" maxlength="500"></textarea></div>
              <div class="mb-3"><label class="form-label">Body</label>
                <textarea name="body" class="form-control" rows="5"></textarea></div>
              <div class="mb-3"><label class="form-label">Featured Image</label>
                <input type="file" name="image" class="form-control" accept="image/*"></div>
              <button type="submit" class="btn btn-theme w-100">Publish Post</button>
            </form>
          </div>
        </div>
        <div class="col-lg-7">
          <div class="dash-card">
            <div class="table-responsive">
              <table class="table dash-table">
                <thead><tr><th>Headline</th><th>Date</th><th>Action</th></tr></thead>
                <tbody>
                  <% blogs.forEach(b => { %>
                  <tr>
                    <td><%= b.headline.substring(0, 45) %><%= b.headline.length > 45 ? '…' : '' %></td>
                    <td class="text-muted small"><%= new Date(b.createdAt).toLocaleDateString() %></td>
                    <td>
                      <a href="/blog/<%= b._id %>" target="_blank" class="btn btn-xs btn-outline-info me-1"><i class="fas fa-eye"></i></a>
                      <form action="/admin/blog/<%= b._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete?')">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-xs btn-outline-danger"><i class="fas fa-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
                  <% if (!blogs.length) { %><tr><td colspan="3" class="text-center py-4 text-muted">No posts yet.</td></tr><% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
