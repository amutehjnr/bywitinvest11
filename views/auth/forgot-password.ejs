<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<section class="auth-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-5 col-md-7">
        <div class="auth-card">
          <div class="auth-header">
            <i class="fas fa-key auth-icon"></i>
            <h3>Forgot Password</h3>
            <p>Enter your email to receive a reset link</p>
          </div>
          <% if (sent) { %>
          <div class="alert alert-success text-center">
            <i class="fas fa-check-circle fa-2x mb-2 d-block"></i>
            If that email is registered, a reset link has been sent. Check your inbox.
          </div>
          <% } else { %>
          <% if (errors.length > 0) { %>
          <div class="alert alert-danger"><% errors.forEach(e => { %><%= e.msg %><% }) %></div>
          <% } %>
          <form action="/auth/forgot-password" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
              <label class="form-label">Email Address</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <input type="email" name="email" class="form-control" placeholder="Your registered email"
                       autocomplete="email" required>
              </div>
            </div>
            <button type="submit" class="btn btn-theme w-100">Send Reset Link</button>
          </form>
          <% } %>
          <div class="auth-footer mt-3">
            <a href="/auth/login" class="auth-link"><i class="fas fa-arrow-left me-1"></i>Back to Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
